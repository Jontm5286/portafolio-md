---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/organisms/Navbar.astro";
import ProjectDetailHero from "../../components/organisms/ProjectDetailHero.astro";
import ChallengeSection from "../../components/organisms/ChallengeSection.astro";
import ProcessSection from "../../components/organisms/ProcessSection.astro";
import ImpactSection from "../../components/organisms/ImpactSection.astro";
import Footer from "../../components/organisms/Footer.astro";
import Typography from "../../components/atoms/Typography.astro";

/**
 * Project Detail Page (Case Study)
 * Dynamically rendered from the projects content collection.
 */
export async function getStaticPaths() {
  const projects = await getCollection("projects");
  const sortedProjects = projects.sort((a, b) => a.data.order - b.data.order);

  return sortedProjects.map((project, index) => ({
    params: { slug: project.id },
    props: {
      project,
      prevProject: index > 0 ? sortedProjects[index - 1] : null,
      nextProject:
        index < sortedProjects.length - 1 ? sortedProjects[index + 1] : null,
    },
  }));
}

const { project, prevProject, nextProject } = Astro.props;
---

<BaseLayout
  title={`${project.data.title} | Miguel Damiron`}
  description={project.data.summary}
>
  <Navbar />

  <main class="project-detail-page">
    <ProjectDetailHero
      title={project.data.title}
      summary={project.data.summary}
      category={project.data.category}
      tags={project.data.tags}
    />

    {
      project.data.challenge && (
        <ChallengeSection
          text={project.data.challenge}
          points={project.data.challengePoints}
        />
      )
    }

    {
      project.data.process && (
        <ProcessSection steps={project.data.process} />
      )
    }

    <section class="dashboard-preview section-padding">
      <div class="container">
        <div class="preview-frame">
          <header class="frame-header">
            <div class="dots">
              <span class="dot"></span>
              <span class="dot"></span>
              <span class="dot"></span>
            </div>
            <Typography tag="span" size="xs" weight="bold" class="uppercase">
              Interactive Dashboard Preview
            </Typography>
          </header>
          <div class="frame-content">
            <img src={project.data.imageUrl} alt="Dashboard Preview" />
          </div>
        </div>
      </div>
    </section>

    {
      project.data.impact && (
        <ImpactSection items={project.data.impact} />
      )
    }

    <section class="tech-stack-applied section-padding">
      <div class="container">
        <div class="stack-footer">
          <Typography tag="h3" size="sm" weight="bold" class="uppercase tracking-widest muted-text">
            Technology Stack Applied
          </Typography>
          <div class="stack-icons">
            {project.data.toolsApplied?.map(tool => (
              <div class="stack-item">
                <Typography tag="span" size="xs" weight="bold">{tool}</Typography>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <nav class="project-navigation">
      <div class="container nav-container">
        {prevProject ? (
          <a href={`/projects/${prevProject.id}`} class="nav-link prev">
            <Typography tag="span" size="xs" weight="bold" class="nav-label">← Previous Project</Typography>
            <Typography tag="p" size="xl" weight="bold" class="nav-title">{prevProject.data.title}</Typography>
          </a>
        ) : <div />}

        <div class="nav-divider"></div>

        {nextProject ? (
          <a href={`/projects/${nextProject.id}`} class="nav-link next">
            <Typography tag="span" size="xs" weight="bold" class="nav-label text-right">Next Project →</Typography>
            <Typography tag="p" size="xl" weight="bold" class="nav-title text-right">{nextProject.data.title}</Typography>
          </a>
        ) : <div />}
      </div>
    </nav>
  </main>

  <Footer />
</BaseLayout>

<style>
  .project-detail-page {
    background-color: var(--color-background);
  }

  .preview-frame {
    background-color: #1a202c;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(0,0,0,0.2);
  }

  .frame-header {
    background-color: #2d3748;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    color: var(--color-neutral-400);
  }

  .dots {
    display: flex;
    gap: 0.5rem;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: #4a5568;
  }

  .dot:nth-child(1) { background-color: #f56565; }
  .dot:nth-child(2) { background-color: #ecc94b; }
  .dot:nth-child(3) { background-color: #48bb78; }

  .frame-content {
    width: 100%;
    aspect-ratio: 16 / 9;
  }

  .frame-content img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .stack-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--color-neutral-200);
    padding-top: 2rem;
  }

  .stack-icons {
    display: flex;
    gap: 2rem;
  }

  .muted-text {
    color: var(--color-neutral-400);
  }

  .project-navigation {
    border-top: 1px solid var(--color-neutral-100);
  }

  .nav-container {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: stretch;
    padding: 0;
  }

  .nav-link {
    padding: 4rem 2rem;
    text-decoration: none;
    transition: background-color 0.3s ease;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .nav-link:hover {
    background-color: var(--color-neutral-100);
  }

  .nav-divider {
    width: 1px;
    background-color: var(--color-neutral-100);
  }

  .nav-label {
    color: var(--color-neutral-400);
    margin-bottom: 0.5rem;
    display: block;
  }

  .nav-title {
    color: var(--color-green-vogue-950);
  }

  .text-right {
    text-align: right;
  }

  .uppercase {
    text-transform: uppercase;
  }

  .tracking-widest {
    letter-spacing: 0.1em;
  }

  @media (max-width: 768px) {
    .stack-footer {
      flex-direction: column;
      gap: 1.5rem;
      align-items: flex-start;
    }
    .nav-container {
      grid-template-columns: 1fr;
    }
    .nav-divider {
      width: 100%;
      height: 1px;
    }
    .nav-link {
      padding: 2rem;
    }
  }
</style>

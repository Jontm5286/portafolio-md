---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/organisms/Navbar.astro";
import Hero from "@/components/organisms/Hero.astro";
import AboutContent from "@/components/organisms/AboutContent.astro";
import FeaturedProjects from "@/components/organisms/FeaturedProjects.astro";
import TechGrid from "@/components/organisms/TechGrid.astro";
import CtaBanner from "@/components/organisms/CtaBanner.astro";
import Footer from "@/components/organisms/Footer.astro";
import ExperienceTimeline from "@/components/organisms/ExperienceTimeline.astro";
import ImpactSummary from "@/components/organisms/ImpactSummary.astro";
---

<BaseLayout>
  <Navbar />

  <main>
    <Hero />
    <AboutContent />
    <ExperienceTimeline />
    <ImpactSummary />
    <FeaturedProjects />
    <TechGrid />
    <CtaBanner />
  </main>

  <Footer />
</BaseLayout>

<style>
  /* Local page styles if needed */
  main {
    display: flex;
    flex-direction: column;
  }
</style>

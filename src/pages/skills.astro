---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/organisms/Navbar.astro";
import TechnicalSkills from "@/components/organisms/TechnicalSkills.astro";
import SoftSkills from "@/components/organisms/SoftSkills.astro";
import CertificationsSection from "@/components/organisms/CertificationsSection.astro";
import Footer from "@/components/organisms/Footer.astro";
import Typography from "@/components/atoms/Typography.astro";
import Button from "@/components/atoms/Button.astro";

/**
 * Skills Page
 * Showcases technical proficiency, soft skills and certifications.
 */
---

<BaseLayout
  title="Skills | Miguel Damiron"
  description="Technical stack, strategic soft skills and professional certifications of Miguel Damiron."
>
  <Navbar />

  <main class="skills-page">
    <header class="page-header section-padding">
      <div class="container">
        <Typography tag="h1" size="5xl" weight="black" class="uppercase main-title">
          Skills<span class="text-accent">.</span>
        </Typography>
        <Typography tag="p" size="lg" color="muted" class="max-w-3xl mt-6">
          A synthesis of technical architecture and strategic communication. I bridge the gap between raw data and executive decision-making through a curated stack of BI tools and methodologies.
        </Typography>
      </div>
    </header>

    <section class="skills-overview pb-24">
      <div class="container">
        <div class="skills-grid">
          <TechnicalSkills />
          <SoftSkills />
        </div>
      </div>
    </section>

    <CertificationsSection />

    <section class="skills-cta section-padding">
      <div class="container">
        <div class="cta-box">
          <div class="cta-content">
            <Typography tag="h2" size="4xl" weight="bold" class="mb-6">
              Ready to operationalize your data?
            </Typography>
            <Typography tag="p" size="lg" color="muted" class="mb-8">
              Let's discuss how my technical skills can solve your specific business challenges.
            </Typography>
          </div>
          <Button variant="primary" size="lg" href="/contact">
            Get in Touch →
          </Button>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .skills-page {
    padding-top: 5rem;
  }

  .main-title {
    color: var(--color-green-vogue-950);
  }

  .text-accent {
    color: var(--color-accent);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 4rem;
    align-items: start;
  }

  .cta-box {
    background-color: var(--color-neutral-100);
    padding: 4rem;
    border-radius: var(--radius-lg);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }

  .max-w-3xl {
    max-width: 48rem;
  }
  .mt-6 {
    margin-top: 1.5rem;
  }
  .mb-6 {
    margin-bottom: 1.5rem;
  }
  .mb-8 {
    margin-bottom: 2rem;
  }
  .pb-24 {
    padding-bottom: 6rem;
  }
  .uppercase {
    text-transform: uppercase;
  }

  @media (max-width: 1024px) {
    .skills-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .cta-box {
      flex-direction: column;
      text-align: center;
      padding: 3rem 2rem;
    }
  }

  @media (max-width: 768px) {
    .skills-page {
      padding-top: 4rem;
    }
  }
</style>

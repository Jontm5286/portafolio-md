---
import { getCollection } from "astro:content";
import Typography from "../atoms/Typography.astro";
import ProjectCard from "./ProjectCard.astro";

/**
 * FeaturedProjects Organism
 * Grid layout for project cards fetched from content collection.
 */
const allProjects = await getCollection("projects");
const projects = allProjects
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3); // Solo mostramos los 3 primeros en la Home
---

<section id="projects" class="projects-section section-padding">
  <div class="container">
    <div class="projects-header mb-12" data-reveal>
      <div>
        <Typography
          tag="span"
          size="xs"
          weight="bold"
          color="accent"
          class="uppercase tracking-widest"
        >
          Portfolio
        </Typography>
        <Typography tag="h2" size="4xl" weight="black" class="uppercase mt-2">
          Featured Projects
        </Typography>
      </div>
      <a href="/projects" class="view-all">
        <Typography
          tag="span"
          size="sm"
          weight="bold"
          class="uppercase tracking-wider"
        >
          View All Works
        </Typography>
      </a>
    </div>

    <div class="projects-grid">
      {
        projects.map((project, index) => (
          <ProjectCard
            title={project.data.title}
            category={project.data.category}
            description={project.data.description}
            imageUrl={project.data.imageUrl}
            tags={project.data.tags}
            href={`/projects/${project.id}`}
            data-reveal
            data-reveal-delay={index * 0.1}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .projects-section {
    background-color: var(--color-background);
  }

  .projects-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  /* Make the third project (featured) span full width if needed or handle 2-1 layout */
  .projects-grid :global(.featured-card) {
    grid-column: span 2;
  }

  .view-all {
    color: var(--color-text-muted);
    transition: color 0.3s ease;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
  }

  .view-all:hover {
    color: var(--color-accent);
  }

  .mb-12 {
    margin-bottom: 3rem;
  }
  .mt-2 {
    margin-top: 0.5rem;
  }
  .uppercase {
    text-transform: uppercase;
  }
  .tracking-widest {
    letter-spacing: 0.1em;
  }
  .tracking-wider {
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
    .projects-grid :global(.featured-card) {
      grid-column: span 1;
    }
    .projects-header {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-md);
    }
  }
</style>

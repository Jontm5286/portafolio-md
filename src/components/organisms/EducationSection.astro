---
import Typography from "../atoms/Typography.astro";

/**
 * EducationSection Organism
 * Showcases academic background with cards.
 */
---

<section class="education-section section-padding">
  <div class="container education-container">
    <div class="education-header">
      <Typography tag="h2" size="4xl" weight="bold" class="section-title">
        Academic Foundation
      </Typography>
      <Typography tag="p" color="muted" class="max-w-xs mt-4">
        The formal training that shaped my technical mindset and strategic
        vision.
      </Typography>
    </div>

    <div class="education-list">
      <div class="education-card">
        <header class="card-header">
          <div class="date-badge">
            <Typography tag="span" size="xs" weight="bold">2018 — 2020</Typography>
          </div>
          <div class="card-icon">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path
                d="M6 12v5c3 3 9 3 12 0v-5"
              ></path></svg
            >
          </div>
        </header>
        <div class="card-body">
          <Typography tag="h3" size="xl" weight="bold" class="degree-title">
            Master of Business Administration (MBA)
          </Typography>
          <Typography tag="p" size="sm" color="muted" class="specialization">
            Focus on Strategic Management & Data Governance
          </Typography>
        </div>
        <div class="card-footer-line"></div>
      </div>

      <div class="education-card">
        <header class="card-header">
          <div class="date-badge">
            <Typography tag="span" size="xs" weight="bold">2008 — 2013</Typography>
          </div>
          <div class="card-icon">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><circle cx="12" cy="12" r="10"></circle><line
                x1="22"
                y1="12"
                x2="18"
                y2="12"></line><line x1="6" y1="12" x2="2" y2="12"></line><line
                x1="12"
                y1="6"
                x2="12"
                y2="2"></line><line x1="12" y1="22" x2="12" y2="18"></line></svg
            >
          </div>
        </header>
        <div class="card-body">
          <Typography tag="h3" size="xl" weight="bold" class="degree-title">
            Electronic Engineering
          </Typography>
          <Typography tag="p" size="sm" color="muted" class="specialization">
            Systems Optimization & Signal Processing Fundamentals
          </Typography>
        </div>
        <div class="card-footer-line"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .education-section {
    background-color: var(--color-neutral-100);
  }

  .education-container {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 4rem;
  }

  .section-title {
    color: var(--color-green-vogue-950);
  }

  .education-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .education-card {
    background-color: var(--color-neutral-0);
    padding: 2.5rem;
    border-radius: var(--radius-sm);
    position: relative;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    transition: transform 0.3s ease;
  }

  .education-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .date-badge {
    background-color: var(--color-accent-warm-light);
    color: var(--color-on-accent-warm);
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
  }

  .card-icon {
    width: 20px;
    height: 20px;
    color: var(--color-green-vogue-950);
    opacity: 0.8;
  }

  .degree-title {
    color: var(--color-green-vogue-950);
    margin-bottom: 0.5rem;
  }

  .card-footer-line {
    position: absolute;
    bottom: 0;
    left: 2.5rem;
    width: 60px;
    height: 3px;
    background-color: var(--color-accent-warm-mid);
  }

  .max-w-xs {
    max-width: 20rem;
  }
  .mt-4 {
    margin-top: 1rem;
  }

  @media (max-width: 900px) {
    .education-container {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>

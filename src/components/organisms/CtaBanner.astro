---
import Typography from '../atoms/Typography.astro';
import Button from '../atoms/Button.astro';

/**
 * CtaBanner Organism
 * A wide call-to-action section meant to encourage contact.
 */
---

<section id="contact" class="cta-section section-padding">
  <div class="container">
    <div class="cta-card">
      <div class="cta-content">
        <Typography tag="h2" size="4xl" weight="bold" class="mb-4">
          Ready to make your data talk?
        </Typography>
        
        <Typography tag="p" size="lg" color="muted" class="mb-8">
          Let's discuss how customized BI solutions can transform your operational efficiency.
        </Typography>

        <Button variant="primary" size="lg" href="mailto:contact@migueldamiron.com">
          Get In Touch
        </Button>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding-bottom: calc(var(--space-xl) * 2);
  }

  .cta-card {
    background: linear-gradient(135deg, var(--color-secondary), var(--color-green-vogue-950));
    border-radius: var(--radius-lg);
    padding: calc(var(--space-xl) * 1.5) var(--space-md);
    text-align: center;
    position: relative;
    overflow: hidden;
    box-shadow: 0 20px 40px color-mix(in srgb, var(--color-neutral-950) 50%, transparent);
  }
  
  /* Decorative background element */
  .cta-card::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at center, color-mix(in srgb, var(--color-neutral-0) 3%, transparent) 0%, transparent 60%);
    z-index: 0;
  }

  .cta-content {
    position: relative;
    z-index: 10;
    max-width: 600px;
    margin: 0 auto;
  }

  .mb-4 { margin-bottom: 1rem; }
  .mb-8 { margin-bottom: 2rem; }
</style>

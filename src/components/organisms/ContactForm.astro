---
import FormField from "../molecules/FormField.astro";
import Button from "../components/atoms/Button.astro";

/**
 * ContactForm Organism
 * Handles the contact form structure.
 */
---

<div class="contact-form-container">
  <form action="#" method="POST" class="contact-form">
    <div class="form-row">
      <FormField
        label="Full Name"
        id="name"
        placeholder="John Doe"
        required={true}
      />
      <FormField
        label="Email Address"
        id="email"
        type="email"
        placeholder="john@company.com"
        required={true}
      />
    </div>

    <FormField
      label="Company / Organization"
      id="company"
      placeholder="Enter your company name"
    />

    <FormField
      label="Your Message"
      id="message"
      type="textarea"
      placeholder="Tell me about your project or inquiry..."
      required={true}
    />

    <div class="form-footer">
      <Button variant="primary" size="lg" type="submit" class="submit-button">
        Send Message <span class="btn-icon">→</span>
      </Button>
    </div>
  </form>
</div>

<style>
  .contact-form-container {
    background-color: var(--color-neutral-0);
    padding: var(--space-xl);
    border-radius: var(--radius-md);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.04);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .form-footer {
    margin-top: 1rem;
  }

  .submit-button {
    width: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .btn-icon {
    font-size: 1.2rem;
    transition: transform 0.3s ease;
  }

  .submit-button:hover .btn-icon {
    transform: translateX(5px);
  }

  @media (max-width: 640px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

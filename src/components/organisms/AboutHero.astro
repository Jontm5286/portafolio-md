---
import { Image } from "astro:assets";
import Typography from "../atoms/Typography.astro";
import Badge from "../atoms/Badge.astro";
import profileImage from "../../../public/miguel.png"; // Importing for optimization

/**
 * AboutHero Organism
 * Main hero section for the About page.
 */
---

<section class="about-hero section-padding">
  <div class="container about-hero-container">
    <div class="about-image-side">
      <div class="image-frame">
        <Image 
          src={profileImage} 
          alt="Miguel Damiron" 
          width={800} 
          height={1000}
          loading="eager" 
          fetchpriority="high"
          class="profile-image" 
        />
      </div>
    </div>

    <div class="about-content-side">
      <div class="title-badge">
        <Typography tag="span" size="xs" weight="bold" class="uppercase">
          The Analytical Architect
        </Typography>
      </div>

      <Typography tag="h1" size="5xl" weight="black" class="name-title mb-6">
        Miguel Damiron
      </Typography>

      <Typography tag="p" size="lg" weight="medium" class="mb-6 bio-intro">
        A Senior Data & BI Manager specializing in transforming complex architectural data blueprints into actionable business intelligence. With over a decade of experience, I bridge the gap between technical engineering precision and strategic executive leadership.
      </Typography>

      <Typography tag="p" color="muted" class="bio-text">
        My approach is defined by the "precision-first" methodology. I believe that data is not just a collection of numbers, but a structural foundation that requires rigorous maintenance and sophisticated orchestration to drive real-world impact.
      </Typography>
    </div>
  </div>
</section>

<style>
  .about-hero {
    padding-top: 8rem;
    background-color: var(--color-background);
  }

  .about-hero-container {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 4rem;
    align-items: center;
  }

  .image-frame {
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
    background-color: var(--color-neutral-100); /* Placeholder color */
  }

  .profile-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.1);
    display: block;
  }

  .title-badge {
    background-color: var(--color-accent-warm-light);
    color: var(--color-on-accent-warm);
    display: inline-block;
    padding: 0.2rem 0.75rem;
    border-radius: 4px;
    margin-bottom: 1.5rem;
  }

  .name-title {
    color: var(--color-green-vogue-950);
  }

  .bio-intro {
    color: var(--color-neutral-800);
    line-height: 1.5;
  }

  .bio-text {
    line-height: 1.6;
  }

  .mb-6 {
    margin-bottom: 1.5rem;
  }
  .uppercase {
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (max-width: 900px) {
    .about-hero-container {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .about-image-side {
      max-width: 400px;
      margin: 0 auto;
    }
  }
</style>

---
import Typography from '@/components/atoms/Typography.astro';
import SocialIcon from '@/components/molecules/SocialIcon.astro';

/**
 * Footer Organism
 * Bottom section containing logo, social links, and copyright info.
 */
const currentYear = new Date().getFullYear();
---

<footer class="footer section-padding">
  <div class="container footer-container">
    <div class="footer-logo">
      <Typography tag="span" size="xl" weight="black" color="accent">MD</Typography>
      <Typography tag="span" size="sm" weight="semibold" class="ml-2">Portfolio</Typography>
    </div>

    <div class="footer-social">
      <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="footer-link">LinkedIn</a>
      <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="footer-link">GitHub</a>
      <a href="mailto:contact@migueldamiron.com" class="footer-link">Email</a>
    </div>

    <div class="footer-copyright">
      <Typography tag="p" size="sm" color="muted">
        &copy; {currentYear} MD Portfolio. All rights reserved.
      </Typography>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-xl);
    padding-bottom: var(--space-xl);
    background-color: var(--color-background);
  }

  .footer-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-lg);
  }

  .footer-logo {
    display: flex;
    align-items: center;
  }

  .ml-2 { margin-left: 0.5rem; }

  .footer-social {
    display: flex;
    gap: var(--space-md);
  }
  
  .footer-link {
      color: var(--color-text-muted);
      font-size: 0.875rem;
      transition: color var(--transition-normal);
  }
  
  .footer-link:hover {
      color: var(--color-accent);
  }

  .footer-copyright {
    text-align: right;
  }

  @media (max-width: 768px) {
    .footer-container {
      flex-direction: column;
      text-align: center;
    }
    
    .footer-copyright {
      text-align: center;
    }
  }
</style>

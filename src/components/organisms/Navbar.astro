---
import Typography from "@/components/atoms/Typography.astro";
import Button from "@/components/atoms/Button.astro";
import NavLink from "@/components/molecules/NavLink.astro";
import ThemeToggle from "@/components/molecules/ThemeToggle.astro";

const navItems = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "Projects", href: "/projects" },
  { label: "Skills", href: "/skills" },
  { label: "Blog", href: "/blog" },
];

const currentPath = Astro.url.pathname;

function isActive(href: string, path: string): boolean {
  if (href === "/") {
    return path === "/" || path === "";
  }
  return path === href || path.startsWith(`${href}/`);
}
---

<header class="navbar">
  <div class="container navbar-container">
    <div class="logo">
      <a href="/" aria-label="Miguel Damiron Home">
        <Typography tag="span" size="2xl" weight="black" class="logo-text">
          MD<span class="text-accent">.</span>
        </Typography>
      </a>
    </div>

    <nav class="nav-links" aria-label="Main Navigation">
      <ul>
        {
          navItems.map((item) => (
            <li>
              <NavLink href={item.href} label={item.label} active={isActive(item.href, currentPath)} />
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="nav-actions">
      <ThemeToggle />
      <Button variant="outline" size="sm" href="/contact" class="contact-btn">Contact Me</Button>
    </div>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background-color: color-mix(in srgb, var(--color-background) 90%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    transition: background-color 0.3s ease;
  }

  .navbar-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
  }

  .logo a {
    display: block;
    text-decoration: none;
  }

  .logo-text {
    color: var(--color-text-primary);
  }

  .text-accent {
    color: var(--color-accent-warm);
  }

  .nav-links ul {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  @media (max-width: 900px) {
    .nav-links {
      display: none;
    }
  }
</style>

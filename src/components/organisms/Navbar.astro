---
import Typography from '../atoms/Typography.astro';
import Button from '../atoms/Button.astro';
import NavLink from '../molecules/NavLink.astro';
import ThemeToggle from '../molecules/ThemeToggle.astro';

const navItems = [
  { label: 'Home', href: '#home' },
  { label: 'About', href: '#about' },
  { label: 'Experience', href: '#experience' },
  { label: 'Projects', href: '#projects' },
  { label: 'Skills', href: '#skills' },
  { label: 'Blog', href: '#blog' },
  { label: 'Contact', href: '#contact' },
];
---

<header class="navbar">
  <div class="container navbar-container">
    <div class="logo">
      <a href="/">
        <Typography tag="span" size="2xl" weight="black" color="accent" class="logo-text">MD</Typography>
      </a>
    </div>

    <nav class="nav-links">
      <ul>
        {navItems.map(item => (
          <NavLink href={item.href} label={item.label} />
        ))}
      </ul>
    </nav>

    <div class="nav-actions">
      <ThemeToggle />
      <Button variant="outline" size="sm" href="#contact">Contact Me</Button>
    </div>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background-color: color-mix(in srgb, var(--color-background) 85%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
  }

  .navbar-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
  }

  .logo a {
    display: block;
  }

  .nav-links ul {
    display: flex;
    gap: 2rem;
  }

  @media (max-width: 900px) {
    .nav-links {
      display: none; /* Hide on mobile for now, can add a hamburger menu later */
    }
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
</style>

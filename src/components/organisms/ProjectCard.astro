---
import Typography from '../atoms/Typography.astro';
import ProjectTag from '../molecules/ProjectTag.astro';

/**
 * ProjectCard Organism
 * A reusable card for displaying a project, supporting different aspect ratios.
 * 
 * @param {string} title - Project title
 * @param {string} category - Project category tag
 * @param {string} imageUrl - Background image URL
 * @param {string} href - Link to project detail
 * @param {boolean} featured - If true, card spans full width (useful for grid)
 */
const { 
  title, 
  category, 
  imageUrl, 
  href = '#',
  featured = false 
} = Astro.props;

const cardClass = `project-card ${featured ? 'featured-card' : 'standard-card'}`;
---

<a href={href} class={cardClass}>
  <div class="card-bg" style={`background-image: url('${imageUrl}');`}></div>
  <div class="card-overlay"></div>
  
  <div class="card-content">
    <ProjectTag label={category} />
    <Typography tag="h3" size="2xl" weight="bold" class="mt-4 card-title shadow-text">
      {title}
    </Typography>
  </div>
</a>

<style>
  .project-card {
    position: relative;
    display: block;
    border-radius: var(--radius-md);
    overflow: hidden;
    group: relative;
    transition: transform var(--transition-normal);
  }

  .standard-card {
    height: 400px;
  }

  .featured-card {
    height: 500px;
    width: 100%;
  }

  .project-card:hover {
    transform: translateY(-5px);
  }

  .card-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform 0.7s ease;
  }

  .project-card:hover .card-bg {
    transform: scale(1.05);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top, 
      color-mix(in srgb, var(--color-neutral-950) 90%, transparent) 0%, 
      color-mix(in srgb, var(--color-neutral-950) 40%, transparent) 50%, 
      transparent 100%
    );
    transition: background 0.3s ease;
  }

  .project-card:hover .card-overlay {
    background: linear-gradient(
      to top, 
      color-mix(in srgb, var(--color-neutral-950) 95%, transparent) 0%, 
      color-mix(in srgb, var(--color-accent) 20%, transparent) 60%, 
      transparent 100%
    );
  }

  .card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: var(--space-lg);
    z-index: 10;
  }

  .mt-4 { margin-top: 1rem; }
  
  .shadow-text {
    text-shadow: 0 2px 4px color-mix(in srgb, var(--color-neutral-950) 80%, transparent);
  }

  @media (max-width: 768px) {
    .standard-card, .featured-card {
      height: 350px;
    }
  }
</style>

---
import Typography from "@/components/atoms/Typography.astro";
import Badge from "@/components/atoms/Badge.astro";

/**
 * ProjectCard Organism
 * Optimized for Lighthouse: 
 * - Fixed aspect ratio to prevent CLS.
 * - Descriptive ARIA labels for accessibility.
 */
interface Props {
  title: string;
  category: string;
  description: string;
  imageUrl: string;
  tags?: string[];
  href?: string;
}

const { title, category, description, imageUrl, tags = [], href = "#", ...rest } = Astro.props;
---

<article
  class="project-card"
  data-category={category.toLowerCase()}
  data-tags={tags.join(",").toLowerCase()}
  {...rest}
>
  <a href={href} class="card-media" aria-label={`View details for ${title}`}>
    <div class="image-container">
      <img 
        src={imageUrl} 
        alt={`Screenshot of ${title} project`} 
        class="project-image" 
        width="800"
        height="500"
        loading="lazy"
        decoding="async"
      />
      <div class="category-tag">
        <Typography tag="span" size="xs" weight="bold" class="uppercase">
          {category}
        </Typography>
      </div>
    </div>
    <div class="media-overlay"></div>
  </a>

  <div class="card-body">
    <Typography tag="h3" size="xl" weight="bold" class="project-title">
      {title}
    </Typography>
    <Typography tag="p" size="sm" color="muted" class="project-description">
      {description}
    </Typography>
    
    <div class="card-tags">
      {tags.slice(0, 3).map(tag => (
        <span class="mini-tag">{tag}</span>
      ))}
    </div>

    <a href={href} class="view-link" aria-label={`Read case study for ${title}`}>
      <Typography tag="span" size="xs" weight="bold">View Case Study</Typography>
      <span class="arrow" aria-hidden="true">→</span>
    </a>
  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    transition: transform 0.3s ease;
  }

  .card-media {
    position: relative;
    border-radius: var(--radius-sm);
    overflow: hidden;
    aspect-ratio: 16 / 10;
    display: block;
    background-color: var(--color-neutral-100);
  }

  .image-container {
    width: 100%;
    height: 100%;
    transition: transform 0.5s ease;
  }

  .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.9);
    display: block;
  }

  .card-media:hover .image-container {
    transform: scale(1.05);
  }

  .category-tag {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background-color: rgba(0, 0, 0, 0.7);
    color: var(--color-neutral-0);
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    z-index: 2;
  }

  .media-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 60%, rgba(0,0,0,0.3));
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .card-media:hover .media-overlay {
    opacity: 1;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .project-title {
    color: var(--color-green-vogue-950);
  }

  .project-description {
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .mini-tag {
    font-size: 0.65rem;
    color: var(--color-neutral-500);
    background-color: var(--color-neutral-100);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-weight: 600;
  }

  .view-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-green-vogue-950);
    margin-top: 0.5rem;
    width: fit-content;
  }

  .view-link:hover {
    color: var(--color-accent);
  }

  .arrow {
    transition: transform 0.3s ease;
  }

  .view-link:hover .arrow {
    transform: translateX(5px);
  }

  .uppercase {
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>

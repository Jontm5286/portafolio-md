---
interface Props {
  name?: string;
  size?: number | string;
  class?: string;
}

const { size = 24, class: className = "" } = Astro.props as Props;
---

<div class={`icon-wrapper ${className}`} style={`width: ${size}px; height: ${size}px;`}>
  <slot />
</div>

<style>
  .icon-wrapper {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .icon-wrapper :global(svg) {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }
</style>

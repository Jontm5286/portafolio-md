---
type ButtonVariant = "primary" | "secondary" | "outline" | "ghost";
type ButtonSize = "sm" | "md" | "lg";

interface Props {
  variant?: ButtonVariant;
  size?: ButtonSize;
  href?: string;
  class?: string;
  type?: "submit" | "reset" | "button";
  [key: string]: unknown;
}

const {
  variant = "primary",
  size = "md",
  href,
  class: className = "",
  ...rest
} = Astro.props as Props;

const Element = href ? "a" : "button";

const baseStyles = "btn-base";
const variants = {
  primary: "variant-primary",
  secondary: "variant-secondary",
  outline: "variant-outline",
  ghost: "variant-ghost",
};

const sizes = {
  sm: "size-sm",
  md: "size-md",
  lg: "size-lg",
};
---

<Element href={href} class:list={[baseStyles, variants[variant], sizes[size], className]} {...rest}>
  <slot />
</Element>

<style>
  .btn-base {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    text-decoration: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    border: 2px solid transparent;
    transition: all var(--transition-normal);
    line-height: 1;
    white-space: nowrap;
    font-family: var(--font-family-body);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  /* Sizes */
  .size-sm {
    padding: 0.6rem 1.25rem;
    font-size: 0.875rem;
    letter-spacing: 0.02em;
  }
  .size-md {
    padding: 0.85rem 1.75rem;
    font-size: 1rem;
  }
  .size-lg {
    padding: 1.15rem 2.5rem;
    font-size: 1.125rem;
    border-radius: var(--radius-md);
  }

  /* Variant Styles */
  .variant-primary {
    background-color: var(--color-action-primary);
    border-color: var(--color-action-primary);
    color: var(--color-neutral-0);
  }

  .variant-primary:hover {
    background-color: var(--color-action-primary-hover);
    border-color: var(--color-action-primary-hover);
    transform: translateY(-3px);
    box-shadow: 0 10px 25px color-mix(in srgb, var(--color-action-primary) 30%, transparent);
  }

  .variant-primary:active {
    transform: translateY(-1px);
  }

  .variant-outline {
    background-color: transparent;
    border-color: var(--color-action-primary);
    color: var(--color-action-primary);
  }

  .variant-outline:hover {
    background-color: var(--color-action-primary);
    color: var(--color-neutral-0);
    transform: translateY(-3px);
    box-shadow: 0 10px 25px color-mix(in srgb, var(--color-action-primary) 20%, transparent);
  }

  .variant-ghost {
    background-color: transparent;
    border-color: transparent;
    color: var(--color-text-secondary);
  }

  .variant-ghost:hover {
    background-color: var(--color-bg-sunken);
    color: var(--color-text-primary);
  }

  /* Dark mode specific fine-tuning */
  :global(.dark-mode) .variant-primary {
    color: var(--color-neutral-950);
    font-weight: 800; /* Bolder text for better readability on light accent */
  }

  :global(.dark-mode) .variant-outline:hover {
    color: var(--color-neutral-950);
  }
</style>

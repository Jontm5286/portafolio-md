---
import Sun from "@/components/icons/Sun.astro";
import Moon from "@/components/icons/Moon.astro";
---

<button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
  <div class="icon-sun">
    <Sun size={20} />
  </div>
  <div class="icon-moon">
    <Moon size={20} />
  </div>
</button>

<script>
  const themeToggle = document.getElementById("theme-toggle");
  const html = document.documentElement;

  // Function to set theme
  const setTheme = (theme: "light" | "dark") => {
    if (theme === "dark") {
      html.classList.add("dark-mode");
    } else {
      html.classList.remove("dark-mode");
    }
    localStorage.setItem("theme", theme);
  };

  // Toggle theme on click
  themeToggle?.addEventListener("click", () => {
    const isDark = html.classList.contains("dark-mode");
    setTheme(isDark ? "light" : "dark");
  });
</script>

<style>
  .theme-toggle {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-primary);
    padding: 0.5rem;
    border-radius: var(--radius-md);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-fast);
    position: relative;
    overflow: hidden;
    width: 40px;
    height: 40px;
  }

  .theme-toggle:hover {
    background-color: var(--color-accent);
    color: var(--color-neutral-0);
    border-color: var(--color-accent);
  }

  .icon-sun,
  .icon-moon {
    position: absolute;
    transition:
      transform 0.5s ease,
      opacity 0.5s ease;
  }

  /* When in dark mode (html.dark-mode), show sun, hide moon */
  :global(.dark-mode) .icon-sun {
    transform: translateY(0);
    opacity: 1;
  }
  :global(.dark-mode) .icon-moon {
    transform: translateY(-40px);
    opacity: 0;
  }

  /* When in light mode (default), show moon, hide sun */
  .icon-sun {
    transform: translateY(40px);
    opacity: 0;
  }
  .icon-moon {
    transform: translateY(0);
    opacity: 1;
  }
</style>

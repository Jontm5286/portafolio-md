---
import Typography from "@/components/atoms/Typography.astro";

/**
 * BlogCard Molecule
 * A card representing a blog post.
 */
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  image?: string;
  tags: string[];
  href: string;
}

const { title, description, pubDate, image, tags, href } = Astro.props;
const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<article class="blog-card">
  <a href={href} class="card-image-wrapper">
    {
      image ? (
        <img src={image} alt={title} class="card-image" />
      ) : (
        <div class="image-placeholder" />
      )
    }
    <div class="card-date">
      <Typography tag="span" size="xs" weight="bold">{formattedDate}</Typography>
    </div>
  </a>

  <div class="card-content">
    <div class="card-tags">
      {
        tags.slice(0, 2).map((tag) => (
          <Typography tag="span" size="xs" weight="bold" class="tag-text uppercase">
            {tag}
          </Typography>
        ))
      }
    </div>

    <a href={href} class="title-link">
      <Typography tag="h3" size="xl" weight="bold" class="card-title">
        {title}
      </Typography>
    </a>

    <Typography tag="p" size="sm" color="muted" class="card-description">
      {description}
    </Typography>

    <a href={href} class="read-more">
      <Typography tag="span" size="xs" weight="bold">Read Article</Typography>
      <span class="arrow">→</span>
    </a>
  </div>
</article>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    transition: transform 0.3s ease;
  }

  .card-image-wrapper {
    position: relative;
    border-radius: var(--radius-sm);
    overflow: hidden;
    aspect-ratio: 16 / 9;
    display: block;
    background-color: var(--color-neutral-100);
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .blog-card:hover .card-image {
    transform: scale(1.05);
  }

  .image-placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--color-green-vogue-950);
    opacity: 0.1;
  }

  .card-date {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    background-color: var(--color-neutral-0);
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  }

  .card-content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .card-tags {
    display: flex;
    gap: 1rem;
    margin-bottom: 0.25rem;
  }

  .tag-text {
    color: var(--color-accent);
    letter-spacing: 0.05em;
  }

  .title-link {
    text-decoration: none;
    color: inherit;
  }

  .card-title {
    color: var(--color-green-vogue-950);
    line-height: 1.3;
    transition: color 0.3s ease;
  }

  .title-link:hover .card-title {
    color: var(--color-accent);
  }

  .card-description {
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .read-more {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-green-vogue-950);
    margin-top: 0.5rem;
    width: fit-content;
  }

  .read-more:hover {
    color: var(--color-accent);
  }

  .arrow {
    transition: transform 0.3s ease;
  }

  .read-more:hover .arrow {
    transform: translateX(5px);
  }

  .uppercase {
    text-transform: uppercase;
  }
</style>

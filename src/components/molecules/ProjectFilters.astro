---
import Typography from "@/components/atoms/Typography.astro";

/**
 * ProjectFilters Molecule
 * Filter bar for the projects gallery.
 */
const filters = ["All", "Tableau", "Power BI", "Business Analysis"];
---

<div class="filters-container">
  <div class="filters-bar">
    {
      filters.map((filter, index) => (
        <button
          class={`filter-btn ${index === 0 ? "active" : ""}`}
          data-category={filter.toLowerCase()}
        >
          <Typography tag="span" size="xs" weight="bold">
            {filter}
          </Typography>
        </button>
      ))
    }
  </div>
</div>

<style>
  .filters-container {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 3rem;
  }

  .filters-bar {
    background-color: var(--color-bg-sunken);
    padding: 0.4rem;
    border-radius: var(--radius-sm);
    display: flex;
    gap: 0.25rem;
  }

  .filter-btn {
    padding: 0.6rem 1.25rem;
    border-radius: var(--radius-xs);
    border: none;
    background: transparent;
    cursor: pointer;
    transition: all 0.3s ease;
    color: var(--color-text-secondary);
  }

  .filter-btn:hover {
    color: var(--color-accent);
  }

  .filter-btn.active {
    background-color: var(--color-bg-card);
    color: var(--color-accent);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
  }

  @media (max-width: 768px) {
    .filters-container {
      justify-content: center;
      overflow-x: auto;
      padding-bottom: 1rem;
    }
    .filters-bar {
      width: max-content;
    }
  }
</style>

<script>
  /**
   * Client-side logic for project filtering.
   */
  const filterButtons = document.querySelectorAll(".filter-btn");
  const projectCards = document.querySelectorAll(".project-card");

  filterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      // Update active state
      filterButtons.forEach((btn) => btn.classList.remove("active"));
      button.classList.add("active");

      const category = button.getAttribute("data-category") || "";

      // Filter project cards
      projectCards.forEach((card) => {
        const htmlCard = card as HTMLElement;
        const cardCategory = card.getAttribute("data-category") || "";
        const cardTags = card.getAttribute("data-tags") || "";

        // Match if category is 'all' OR filter exists in category OR filter exists in tags
        if (category === "all" || cardCategory.includes(category) || cardTags.includes(category)) {
          htmlCard.style.display = "flex";
        } else {
          htmlCard.style.display = "none";
        }
      });
    });
  });
</script>

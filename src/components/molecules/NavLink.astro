---
import Typography from "@/components/atoms/Typography.astro";

interface Props {
  href: string;
  label: string;
  active?: boolean;
}

const { href, label, active = false } = Astro.props;
---

<li class="nav-item">
  <a href={href} {...(active ? { "aria-current": "page" } : {})}>
    <Typography tag="span" size="sm" weight="medium" class="nav-text uppercase tracking-widest">
      {label}
    </Typography>
  </a>
</li>

<style>
  .nav-item {
    position: relative;
    padding: 0.5rem 0;
  }

  .nav-text {
    transition: color 0.3s ease;
    color: var(--color-text-muted);
  }

  .nav-item:hover .nav-text {
    color: var(--color-text-primary);
  }

  /* Animated underline effect */
  .nav-item::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-accent);
    transition: width 0.3s ease;
  }

   .nav-item:hover::after {
    width: 100%;
  }

  .nav-item:has([aria-current="page"]) .nav-text {
    color: var(--color-text-primary);
  }

  .nav-item:has([aria-current="page"])::after {
    width: 100%;
  }

  .tracking-widest {
    letter-spacing: 0.1em;
  }
</style>

---
import '../styles/global.css';

/**
 * BaseLayout Component
 * The main wrapper for all pages, containing SEO metadata and global styles.
 * 
 * @param {string} title - Page title
 * @param {string} description - Meta description for SEO
 */
const { 
  title = 'Miguel Damiron | Senior Data & BI Manager', 
  description = 'Portfolio of Miguel Damiron, specializing in Data Engineering, BI, and Business Intelligence solutions.' 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Theme initialization script -->
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();

      if (theme === 'dark') {
        document.documentElement.classList.add('dark-mode');
      } else {
        document.documentElement.classList.remove('dark-mode');
      }
    </script>
    
    <!-- Google Fonts Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* Page transition or global body tweaks can go here */
  :root {
    /* Ensure layout stability */
    overflow-x: hidden;
  }
</style>
